# Copy this file to .env and fill in your actual keys.
# .env is gitignored — never commit real credentials.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your real keys

# ── Anthropic (Claude) ──────────────────────────────────────────────────────────
# Required for: --provider anthropic
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (GPT) ───────────────────────────────────────────────────────────────
# Required for: --provider openai
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Azure OpenAI (optional) ────────────────────────────────────────────────────
# Only needed if using Azure-hosted OpenAI instead of api.openai.com
# OPENAI_API_BASE=https://your-resource.openai.azure.com
# OPENAI_API_VERSION=2024-02-01

# ── Ollama (local, no key needed) ──────────────────────────────────────────────
# Override only if Ollama is not running on the default localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
